PORT=3001
DATABASE_URL=postgres://localhost:5432/heureka_v1
JWT_SECRET=change-me-in-production

# ── Mistral La Plateforme (inférence IA) ─────────────────────────────────────
# Clé requise pour toute analyse de pièce, extraction CERFA, structuration PLU
# et explication de procédure. Sans cette clé, les call sites callAi() lèvent
# « MISTRAL_API_KEY non configurée » et le wizard citoyen affichera un message
# d'« analyse indisponible » sur chaque dépôt de pièce.
# Compte : https://console.mistral.ai → API Keys.
MISTRAL_API_KEY=
# Optionnel : override de la base API (par défaut https://api.mistral.ai/v1).
# MISTRAL_API_BASE=https://api.mistral.ai/v1
#
# Dépendance système : pdftoppm (poppler-utils) doit être installé sur l'hôte
# — Pixtral n'accepte pas le PDF natif, on convertit la 1re page en PNG avant
# envoi. Sur Railway/Nixpacks, c'est garanti par nixpacks.toml à la racine.

# ── PISTE / Légifrance (DILA) ────────────────────────────────────────────────
# Souscription via https://piste.gouv.fr (Menu API > Consentement CGU API,
# puis Applications > Modifier > cocher l'API Légifrance).
# Ne jamais committer les valeurs réelles : .env est gitignoré.
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=
# Sandbox par défaut. Pour la prod, dé-commenter :
# PISTE_API_BASE_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app
# PISTE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token
