PORT=3001
DATABASE_URL=postgres://localhost:5432/heureka_v1
JWT_SECRET=change-me-in-production

# ── Mistral La Plateforme (inférence IA) ─────────────────────────────────────
# Clé requise pour toute analyse de pièce, extraction CERFA, structuration PLU
# et explication de procédure. Sans cette clé, les call sites callAi() lèvent
# « MISTRAL_API_KEY non configurée » et le wizard citoyen affichera un message
# d'« analyse indisponible » sur chaque dépôt de pièce.
# Compte : https://console.mistral.ai → API Keys.
MISTRAL_API_KEY=
# Optionnel : override de la base API (par défaut https://api.mistral.ai/v1).
# MISTRAL_API_BASE=https://api.mistral.ai/v1
#
# Dépendance système : pdftoppm (poppler-utils) doit être installé sur l'hôte
# — Pixtral n'accepte pas le PDF natif, on convertit la 1re page en PNG avant
# envoi. Sur le VPS OVH, c'est provisionné par le script de setup (`apt install
# poppler-utils`). En local : `apt install poppler-utils` ou `brew install poppler`.

# ── PISTE / Légifrance (DILA) ────────────────────────────────────────────────
# Souscription via https://piste.gouv.fr (Menu API > Consentement CGU API,
# puis Applications > Modifier > cocher l'API Légifrance).
# Ne jamais committer les valeurs réelles : .env est gitignoré.
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=
# Sandbox par défaut. Pour la prod, dé-commenter :
# PISTE_API_BASE_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app
# PISTE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token

# ── FranceConnect (OpenID Connect) ───────────────────────────────────────────
# Connexion « S'identifier avec FranceConnect ». TANT QUE FC_CLIENT_ID,
# FC_CLIENT_SECRET et FC_REDIRECT_URI ne sont pas tous renseignés, le bouton
# FranceConnect reste masqué et les routes /api/auth/franceconnect/* renvoient
# 503 — l'auth email/mot de passe continue de fonctionner normalement.
#
# Identifiants à créer sur l'espace partenaires FranceConnect (bac à sable) :
#   https://partenaires.franceconnect.gouv.fr → créer un fournisseur de service.
# Le `redirect_uri` doit être déclaré au caractère près côté FranceConnect.
FC_CLIENT_ID=
FC_CLIENT_SECRET=
# Doit pointer la route de callback de l'API, ex. en local :
#   http://localhost:3001/api/auth/franceconnect/callback
# et en prod l'URL publique équivalente.
FC_REDIRECT_URI=
# Issuer OIDC. Par défaut : bac à sable FCP « low ». Pour la prod, remplacer par
# l'issuer FranceConnect de production.
# FC_ISSUER_URL=https://fcp-low.sbx.dev-franceconnect.fr/api/v2
# Scopes d'identité demandés (espacés). Défaut : openid given_name family_name email
# FC_SCOPES=openid given_name family_name email
# URL de retour après déconnexion FranceConnect (RP-initiated logout). Optionnel.
# FC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login

# ── Front / CORS ─────────────────────────────────────────────────────────────
# Origines autorisées (whitelist CORS + base des liens dans les emails). Liste
# séparée par des virgules. DOIT inclure TOUS les sous-domaines servis, y compris
# le portail super-admin admin.heurekia.com (sans quoi la console d'admin se voit
# refuser ses requêtes en prod). En local, l'origine unique http://localhost:5173
# suffit (le portail admin y cohabite sous /admin).
# FRONTEND_URLS=https://www.heurekia.com,https://app.heurekia.com,https://admin.heurekia.com
# Repli mono-origine (utilisé si FRONTEND_URLS est absent) :
# FRONTEND_URL=https://app.heurekia.com
