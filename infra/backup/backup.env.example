# Configuration des sauvegardes HEUREKA
# Copier dans /etc/heureka/backup.env (mode 600) et compléter avec les
# valeurs détectées par ./discover.sh.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Le mot de passe n'est PAS stocké ici : utiliser ~/.pgpass (mode 600) :
#   127.0.0.1:5432:heureka_v1:heureka:<mot_de_passe>
PG_DATABASE="heureka_v1"
PG_USER="heureka"
PG_HOST="127.0.0.1"
PG_PORT="5432"

# ─── Fichiers déposés ────────────────────────────────────────────────────────
# Répertoire contenant les PDF déposés par les pétitionnaires.
# Sur Railway legacy : apps/api/uploads. Sur le VPS, idéalement déplacé
# vers un volume dédié type /var/lib/heureka/uploads.
UPLOADS_DIR="/var/lib/heureka/uploads"

# ─── Application ─────────────────────────────────────────────────────────────
APP_DIR="/opt/heureka"
APP_ENV_FILE="/opt/heureka/apps/api/.env"
NGINX_CONF_DIR="/etc/nginx"
# Utilisateurs PM2 dont sauvegarder ~/.pm2/dump.pm2 (séparés par espace)
PM2_USERS="root"
# Liste des units systemd à sauvegarder (séparées par espace) — vide si PM2 seul
SYSTEMD_UNITS=""

# ─── Cible locale ────────────────────────────────────────────────────────────
BACKUP_ROOT="/var/backups/heureka"
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6

# ─── Chiffrement ─────────────────────────────────────────────────────────────
# GPG symétrique : passphrase dans un fichier root-only.
# La même passphrase doit être stockée dans le coffre Bitwarden de l'équipe.
GPG_PASSPHRASE_FILE="/etc/heureka/backup.passphrase"
# Algorithme par défaut (AES256 + SHA512)
GPG_CIPHER="AES256"

# ─── Hors-site (OVH Object Storage via rclone) ───────────────────────────────
# Configurer le remote avec `rclone config` — type s3, provider Other.
# Endpoints OVH :
#   - Gravelines : s3.gra.io.cloud.ovh.net
#   - Strasbourg : s3.sbg.io.cloud.ovh.net
#   - Roubaix    : s3.rbx.io.cloud.ovh.net
RCLONE_REMOTE="ovh-s3"
RCLONE_BUCKET="heureka-backups"

# ─── Verify / restore test ───────────────────────────────────────────────────
# Base utilisée pour le restore test hebdomadaire (sera DROP/CREATE à chaque run)
VERIFY_DATABASE="heureka_verify"
